{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "shell",
          "style": "plain",
          "foreground": "#FF7043",
          "template": "´äá {{ .Name }} "
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "#45F1C2",
          "template": "´Çç {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#0CA0D8",
          "properties": {
            "folder_separator_icon": "/",
            "style": "folder",
            "mapped_locations": {
              "~": "~"
            }
          },
          "template": "´ü╗ {{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#FFEB3B",
          "foreground_templates": ["{{ if or (.Working.Changed) (.Staging.Changed) }}#FF7043{{ end }}"],
          "properties": {
            "fetch_status": true,
            "fetch_stash_count": true,
            "fetch_upstream_icon": true
          },
          "template": "¯£Ñ {{ .HEAD }}{{ if .Staging.Changed }} ´üå {{ .Staging.String }}{{ end }}{{ if .Working.Changed }} ´üä {{ .Working.String }}{{ end }}{{ if gt .StashCount 0 }} ´ÜÆ {{ .StashCount }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#FFB74D",
          "properties": {
            "always_enabled": false,
            "style": "austin",
            "threshold": 1000
          },
          "template": "´ëÆ {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "python",
          "style": "plain",
          "foreground": "#FFD43B",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": true
          },
          "template": "¯êÁ {{ if .Venv }}{{ .Venv }}{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "type": "node",
          "style": "plain",
          "foreground": "#6CA35E",
          "properties": {
            "display_mode": "files",
            "fetch_package_manager": true,
            "npm_icon": "¯£×",
            "yarn_icon": "´ÿÜ"
          },
          "template": "{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }}{{ else }}¯£ÿ{{ end }} {{ .Full }} "
        },
        {
          "type": "ruby",
          "style": "plain",
          "foreground": "#E51400",
          "properties": {
            "display_mode": "files"
          },
          "template": "¯×æ {{ .Full }} "
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "#29BEB0",
          "properties": {
            "display_mode": "files"
          },
          "template": "¯ÿª {{ .Full }} "
        },
        {
          "type": "os",
          "style": "plain",
          "foreground": "#8BC34A",
          "template": "{{ if .WSL }}¯£Å WSL {{ end }}{{ .Icon }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "root",
          "style": "plain",
          "foreground": "#FF5252",
          "template": "{{ if .Root }}´âº {{ end }}"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground_templates": ["{{ if gt .Code 0 }}#FF5252{{ else }}#4CAF50{{ end }}"],
          "properties": {
            "always_enabled": false
          },
          "template": "{{ if gt .Code 0 }}´Çì {{ .Code }} {{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#9A86FD",
          "template": "´äà "
        }
      ]
    }
  ]
}
